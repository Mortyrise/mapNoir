# Scene provider: 'mapillary' or 'google'
SCENE_PROVIDER=mapillary

# Mapillary access token (free: https://www.mapillary.com/developer)
MAPILLARY_TOKEN=MLY|your_token_here

# Google Maps API key (only needed if SCENE_PROVIDER=google)
GOOGLE_MAPS_API_KEY=your_key_here

# Server port (default: 3001)
PORT=3001
